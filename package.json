{
  "name": "scala-steward-action",
  "description": "A GitHub Action to launch Scala Steward in your repository",
  "type": "module",
  "scripts": {
    "build": "npm run build-main && npm run build-post",
    "build-main": "ncc build --target es2024 src/action/main.ts && mv dist/index.js dist/main.js",
    "build-post": "ncc build --target es2024 src/action/post.ts && mv dist/index.js dist/post.js",
    "docs": "TS_NODE_TRANSPILE_ONLY=true node --loader ts-node/esm src/utils/docs.ts && markdown-toc-gen update README.md",
    "contributors:add": "all-contributors add",
    "contributors:generate": "all-contributors generate",
    "contributors:check": "all-contributors check",
    "test": "xo && TS_NODE_TRANSPILE_ONLY=true NODE_OPTIONS='--loader=ts-node/esm --experimental-specifier-resolution=node' c8 ava",
    "report": "c8 report",
    "all": "npm run build && npm test && npm run report"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scala-steward-org/scala-steward-action.git"
  },
  "keywords": [
    "actions",
    "scala",
    "dependency-update",
    "scala-steward"
  ],
  "author": "alejandrohdezma",
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/cache": "^6.0.1",
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.1.1",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/request": "^10.0.10",
    "@types/sinon": "^21.0.1",
    "jssha": "^3.3.1"
  },
  "devDependencies": {
    "@ava/typescript": "^7.0.0",
    "@tsconfig/node20": "^20.1.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@vercel/ncc": "^0.38.4",
    "all-contributors-cli": "^6.26.1",
    "ava": "^8.0.1",
    "c8": "^11.0.0",
    "js-yaml": "^4.2.0",
    "markdown-toc-gen": "^1.2.0",
    "sinon": "^22.0.0",
    "ts-node": "^10.9.2",
    "ts-pattern": "^5.9.0",
    "typescript": "^6.0.3",
    "xo": "^2.0.2"
  },
  "xo": {
    "space": true,
    "semicolon": false,
    "rules": {
      "@typescript-eslint/naming-convention": 0,
      "@stylistic/curly-newline": [
        "error",
        {
          "multiline": true,
          "minElements": 1,
          "consistent": true
        }
      ]
    }
  },
  "ava": {
    "files": [
      "src/**/*.test.ts"
    ],
    "extensions": {
      "ts": "module"
    }
  },
  "c8": {
    "all": true,
    "src": "src",
    "exclude": [
      "src/core/!(types.ts)",
      "src/action",
      "src/**/*.test.ts",
      "src/utils"
    ],
    "reporter": [
      "text",
      "cobertura"
    ]
  }
}